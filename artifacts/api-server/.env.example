## Backend (Express) environment variables

# Server port (Railway provides PORT automatically; set for local dev)
PORT=3001

# Supabase Postgres connection string (use the Supabase project's connection string)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# OpenAI (or OpenAI-compatible) settings
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=

# Optional: Comma-separated allowed origins for CORS (set this in production)
# Example: https://your-vercel-app.vercel.app
CORS_ORIGIN=
