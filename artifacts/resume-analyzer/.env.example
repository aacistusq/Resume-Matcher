## Frontend (Vite) environment variables
#
# Required for production builds/deployments.
# Local dev can work without VITE_API_BASE_URL if you run the frontend and backend under the same origin
# (or provide your own dev proxy).

# Optional: Backend base URL (no trailing slash recommended).
# - Local example: http://localhost:3001
# - Production example: https://your-railway-service.up.railway.app
VITE_API_BASE_URL=

# Optional: Vite base path (default "/")
BASE_PATH=/

# Optional: Dev server port (default 5173)
PORT=5173
